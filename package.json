{
  "displayName": "Homebridge Mammotion",
  "name": "homebridge-mammotion",
  "version": "0.1.0",
  "description": "Homebridge plugin for Mammotion mowers (Luba, Yuka) using PyMammotion",
  "type": "commonjs",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist/**/*",
    "config.schema.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "postinstall": "node ./scripts/bootstrap-python.js",
    "build": "rimraf dist && tsc && npm run copy:bridge",
    "copy:bridge": "mkdir -p dist/python && cp src/python/bridge.py dist/python/bridge.py",
    "watch": "tsc -w",
    "lint": "eslint src --ext .ts",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build",
    "test": "echo \"No tests\" && exit 0"
  },
  "engines": {
    "homebridge": ">=1.8.0",
    "node": ">=20.0.0"
  },
  "keywords": [
    "homebridge-plugin",
    "mammotion",
    "luba",
    "yuka"
  ],
  "author": "Tom Willmot <tom@willmot.co.uk>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/willmot/homebridge-mammotion.git"
  },
  "bugs": {
    "url": "https://github.com/willmot/homebridge-mammotion/issues"
  },
  "homepage": "https://github.com/willmot/homebridge-mammotion#readme",
  "homebridge": {
    "pluginAlias": "Mammotion",
    "platform": "Mammotion"
  },
  "peerDependencies": {
    "homebridge": "^1.8.0 || ^2.0.0-beta.75"
  },
  "devDependencies": {
    "@types/node": "^22.13.14",
    "eslint": "^9.22.0",
    "homebridge": "^1.11.0",
    "rimraf": "^6.0.1",
    "typescript": "^5.8.2"
  }
}
